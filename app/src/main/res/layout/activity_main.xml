<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#071321">

    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_gravity="top|start"
        android:background="@drawable/bg_login_glow_warm"
        android:translationX="-60dp"
        android:translationY="-40dp" />

    <View
        android:layout_width="360dp"
        android:layout_height="360dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/bg_login_glow_cool"
        android:translationX="90dp"
        android:translationY="90dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_login_screen_overlay" />

    <ScrollView
        android:id="@+id/loginContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="42dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="180dp"
                android:background="@drawable/bg_login_card"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="26dp"
                android:paddingEnd="18dp"
                android:paddingBottom="26dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_login_pill_label"
                    android:gravity="center"
                    android:paddingStart="26dp"
                    android:paddingEnd="26dp"
                    android:text="@string/login_brand"
                    android:textColor="#F7D08A"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/bg_login_segment"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_login_segment_active"
                        android:gravity="center"
                        android:text="@string/login_tab_login"
                        android:textColor="#131A27"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/login_tab_register"
                        android:textColor="#CDD3DE"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="28dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_login_badge_glow" />

                    <TextView
                        android:layout_width="126dp"
                        android:layout_height="126dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_login_badge"
                        android:gravity="center"
                        android:rotation="-8"
                        android:text="@string/login_badge_text"
                        android:textColor="#0F1A2B"
                        android:textSize="42sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/login_username_label"
                    android:textColor="#F1F4F8"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_login_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_login_user" />

                    <EditText
                        android:id="@+id/usernameInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:autofillHints="username"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:hint="@string/login_username_hint"
                        android:imeOptions="actionNext"
                        android:inputType="text"
                        android:padding="0dp"
                        android:textColor="#F3F5F7"
                        android:textColorHint="#6D7584"
                        android:textSize="17sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="@string/login_password_label"
                    android:textColor="#F1F4F8"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_login_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_login_shield" />

                    <EditText
                        android:id="@+id/passwordInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:autofillHints="password"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:hint="@string/login_password_hint"
                        android:imeOptions="actionDone"
                        android:inputType="textPassword"
                        android:padding="0dp"
                        android:textColor="#F3F5F7"
                        android:textColorHint="#6D7584"
                        android:textSize="17sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_login_circle_outline" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/login_remember_me"
                        android:textColor="#E9EDF2"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/login_auto_jump_tip"
                        android:textColor="#D7A85B"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/loginStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:minHeight="20dp"
                    android:textColor="#FF8A7A"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/loginProgress"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
                    android:indeterminateTint="#FFC96D"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_login_button"
                    android:elevation="4dp"
                    android:stateListAnimator="@null"
                    android:text="@string/login_action"
                    android:textAllCaps="false"
                    android:textColor="#0F1B2B"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_no_account"
                        android:textColor="#BFC5CF"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/login_register_now"
                        android:textColor="#F1C36F"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>
